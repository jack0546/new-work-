rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── HELPER FUNCTIONS ────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidStatus() {
      return request.resource.data.orderStatus in [
        'pending',
        'processing',
        'shipped',
        'delivered',
        'cancelled'
      ];
    }

    // ─── ORDERS COLLECTION ───────────────────────────────────────────
    match /orders/{orderId} {

      // Only authenticated users can create orders
      allow create: if isAuthenticated() && request.resource.data.orderStatus == 'pending';

      // ✅ USER: Read only their own orders
      // ✅ ADMIN: Read ALL orders
      allow read: if isOwner(resource.data.userId) || isAdmin();

      // ✅ ADMIN ONLY: Update any order (status, tracking, notes)
      // ✅ USER: Can only cancel their own PENDING order
      allow update: if isAdmin() && isValidStatus()
                    || (isOwner(resource.data.userId)
                        && resource.data.orderStatus == 'pending'
                        && request.resource.data.orderStatus == 'cancelled');

      // ✅ ADMIN ONLY: Delete orders
      allow delete: if isAdmin();
    }

    // ─── USERS COLLECTION ────────────────────────────────────────────
    match /users/{userId} {
      // Users can read their own doc, admins can read/write all
      // Users CANNOT write to their own doc (prevents privilege escalation)
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
    }

    // ─── USER ORDERS SUBCOLLECTION ───────────────────────────────────
    match /users/{userId}/orders/{orderId} {
      // Owner can read and create their own orders, admin can read/write all
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.orderStatus == 'pending';
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ─── PRODUCTS COLLECTION ─────────────────────────────────────────
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}